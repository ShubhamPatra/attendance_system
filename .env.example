MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/attendance_system?retryWrites=true&w=majority
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_SECONDS=1.0

SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=0
EMBEDDING_BACKEND=arcface
ENABLE_RBAC=0
ENABLE_RESTX_API=0

STRICT_STARTUP_CHECKS=1
STARTUP_CAMERA_PROBE=0
CAMERA_HEALTHCHECK_INDEX=0

SOCKETIO_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

ABSENCE_THRESHOLD=75

CAMERA_INDICES=0

BACKUP_RETENTION_DAYS=30
UPLOAD_RETENTION_SECONDS=3600

RECOGNITION_THRESHOLD=0.50
RECOGNITION_MIN_CONFIDENCE=0.55
RECOGNITION_MIN_DISTANCE_GAP=0.04
RECOGNITION_CONFIDENCE_ALPHA=2.3
RECOGNITION_CONFIRM_FRAMES=2

DETECTION_INTERVAL_MIN=3
DETECTION_INTERVAL_MAX=15
TRACK_DETECTOR_MISS_TOLERANCE=2

LIVENESS_CONFIDENCE_THRESHOLD=0.55
LIVENESS_REAL_FAST_CONFIDENCE=0.72
LIVENESS_HISTORY_SIZE=8
LIVENESS_MIN_HISTORY=3
LIVENESS_REAL_VOTE_RATIO=0.7
LIVENESS_SPOOF_VOTE_RATIO=0.6
LIVENESS_SPOOF_CONFIDENCE_MIN=0.6
LIVENESS_SPOOF_WEAK_CONFIDENCE_MIN=0.45
LIVENESS_STRONG_SPOOF_CONFIDENCE=0.85
LIVENESS_NO_ENCODE_MARGIN=0.03
SPOOF_HOLD_SECONDS=1.5
TRACK_STATE_PENDING_SECONDS=2.5
ANTI_SPOOF_PAD_RATIO_BASE=0.12
ANTI_SPOOF_PAD_RATIO_MAX=0.3
ANTI_SPOOF_PAD_MIN_PIXELS=8
ANTI_SPOOF_DEVICE_ID=0

INCREMENTAL_LEARNING_CONFIDENCE=0.92
INCREMENTAL_LEARNING_MIN_LIVENESS=0.60
MAX_ENCODINGS_PER_STUDENT=15

BRIGHTNESS_MAX=250.0

PPE_DETECTION_ENABLED=0
PPE_MODEL_PATH=
PPE_MASK_THRESHOLD=0.6
PPE_CAP_THRESHOLD=0.6
PPE_MIN_CONFIDENCE=0.55
PPE_HISTORY_SIZE=6
PPE_MIN_HISTORY=3
PPE_VOTE_RATIO=0.6
PPE_MAX_LATENCY_MS=60.0

OCCLUDED_RECOGNITION_THRESHOLD_DELTA=0.05
OCCLUDED_MIN_DISTANCE_GAP=0.08
OCCLUDED_MIN_CONFIDENCE=0.5
OCCLUDED_DISABLE_INCREMENTAL_LEARNING=1

API_RATE_LIMIT_WINDOW_SEC=60
API_RATE_LIMIT_MAX_REQUESTS=30

# Email Notifications (SMTP) - Optional; leave NOTIFICATIONS_ENABLED=0 to disable
NOTIFICATIONS_ENABLED=0
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=1
NOTIFICATION_FROM_EMAIL=noreply@autoattendance.local
NOTIFICATION_FROM_NAME=AutoAttendance System
NOTIFICATION_RATE_LIMIT_SECONDS=3600

ANTI_SPOOF_MODEL_DIR=
SILENT_FACE_PATH=

# -- Performance Tuning (real-time pipeline) --
# Scale factor on processing frame (0.1–1.0); lower = faster, less accurate
PERF_FRAME_SCALE=1.0
# Max simultaneous tracked faces; new detections ignored beyond this
PERF_MAX_FACES=5
# Re-attempt recognition on unidentified tracks every N detection cycles
PERF_RECOGNITION_INTERVAL=3
# Re-evaluate liveness on uncertain tracks every N detection cycles
PERF_ANTISPOOF_INTERVAL=3
# Frame cooldown after a track is recognised
PERF_RECOGNITION_COOLDOWN_FRAMES=30
# Use KCF tracker (~3× faster than CSRT, less accurate); 0=CSRT, 1=KCF
PERF_USE_KCF_TRACKER=0
# JPEG encode quality (0–100); lower = faster encode + smaller payload
PERF_JPEG_QUALITY=80

# Debug and bypass flags
DEBUG_MODE=0
BYPASS_ANTISPOOF=0
BYPASS_MOTION_DETECTION=0
BYPASS_QUALITY_GATE=0
