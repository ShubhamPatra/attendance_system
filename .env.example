MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/attendance_system?retryWrites=true&w=majority
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_SECONDS=1.0
SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=0

STRICT_STARTUP_CHECKS=1
STARTUP_CAMERA_PROBE=0
CAMERA_HEALTHCHECK_INDEX=0

CELERY_DATA_DIR=celery_data
CELERY_BROKER_URL=filesystem://
CELERY_RESULT_BACKEND=file:///absolute/path/to/attendance_system/celery_data/results
SOCKETIO_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

ABSENCE_THRESHOLD=75

CAMERA_INDICES=0

BACKUP_RETENTION_DAYS=30

LIVENESS_CONFIDENCE_THRESHOLD=0.55
INCREMENTAL_LEARNING_CONFIDENCE=0.92
MAX_ENCODINGS_PER_STUDENT=15
ANTI_SPOOF_MODEL_DIR=
SILENT_FACE_PATH=

DEBUG_MODE=0
BYPASS_ANTISPOOF=0
BYPASS_MOTION_DETECTION=0
BYPASS_QUALITY_GATE=0
