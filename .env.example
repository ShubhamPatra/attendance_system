CELERY_RESULT_BACKEND=
SOCKETIO_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

ABSENCE_THRESHOLD=75

CAMERA_INDICES=0

BACKUP_RETENTION_DAYS=30
UPLOAD_RETENTION_SECONDS=3600

RECOGNITION_THRESHOLD=0.50
RECOGNITION_MIN_CONFIDENCE=0.55
RECOGNITION_MIN_DISTANCE_GAP=0.04
RECOGNITION_CONFIDENCE_ALPHA=2.3
RECOGNITION_CONFIRM_FRAMES=2

DETECTION_INTERVAL_MIN=3
DETECTION_INTERVAL_MAX=15
TRACK_DETECTOR_MISS_TOLERANCE=2

LIVENESS_CONFIDENCE_THRESHOLD=0.55
LIVENESS_REAL_FAST_CONFIDENCE=0.72
LIVENESS_HISTORY_SIZE=8
LIVENESS_MIN_HISTORY=3
LIVENESS_REAL_VOTE_RATIO=0.7
LIVENESS_SPOOF_VOTE_RATIO=0.6
LIVENESS_SPOOF_CONFIDENCE_MIN=0.6
LIVENESS_SPOOF_WEAK_CONFIDENCE_MIN=0.45
LIVENESS_STRONG_SPOOF_CONFIDENCE=0.85
LIVENESS_NO_ENCODE_MARGIN=0.03
SPOOF_HOLD_SECONDS=1.5
TRACK_STATE_PENDING_SECONDS=2.5
ANTI_SPOOF_PAD_RATIO_BASE=0.12
ANTI_SPOOF_PAD_RATIO_MAX=0.3
ANTI_SPOOF_PAD_MIN_PIXELS=8
ANTI_SPOOF_DEVICE_ID=0

INCREMENTAL_LEARNING_CONFIDENCE=0.92
INCREMENTAL_LEARNING_MIN_LIVENESS=0.60
MAX_ENCODINGS_PER_STUDENT=15

BRIGHTNESS_MAX=250.0

PPE_DETECTION_ENABLED=0
PPE_MODEL_PATH=
PPE_MASK_THRESHOLD=0.6
PPE_CAP_THRESHOLD=0.6
PPE_MIN_CONFIDENCE=0.55
PPE_HISTORY_SIZE=6
PPE_MIN_HISTORY=3
PPE_VOTE_RATIO=0.6
PPE_MAX_LATENCY_MS=60.0

OCCLUDED_RECOGNITION_THRESHOLD_DELTA=0.05
OCCLUDED_MIN_DISTANCE_GAP=0.08
OCCLUDED_MIN_CONFIDENCE=0.5
OCCLUDED_DISABLE_INCREMENTAL_LEARNING=1

API_RATE_LIMIT_WINDOW_SEC=60
API_RATE_LIMIT_MAX_REQUESTS=30

ANTI_SPOOF_MODEL_DIR=
SILENT_FACE_PATH=

DEBUG_MODE=0
BYPASS_ANTISPOOF=0
